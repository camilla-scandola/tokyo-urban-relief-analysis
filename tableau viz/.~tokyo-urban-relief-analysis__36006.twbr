    <worksheet name='Urban Relief Index Map'>
      <table>
        <view>
          <datasources>
            <datasource caption='casbee.csv+ (Multiple Connections)' name='federated.1qrzfvr1ydsfw11d7qg0x13vauk4' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.1qrzfvr1ydsfw11d7qg0x13vauk4'>
            <column caption='Park Index (0–100)' datatype='real' name='[Calculation_6146308841357334]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([park_area_m2]) - WINDOW_MIN(SUM([park_area_m2])))&#10;/&#10;(WINDOW_MAX(SUM([park_area_m2])) - WINDOW_MIN(SUM([park_area_m2])))&#10;* 100'>
                <table-calc ordering-field='[federated.1qrzfvr1ydsfw11d7qg0x13vauk4].[tokyo_ward]' ordering-type='Field' />
              </calculation>
            </column>
            <column caption='Green buildings Index' datatype='real' name='[Calculation_6146308842442778]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#10;SUM([Calculation_6146309593317412])&#10;-&#10;WINDOW_MIN(SUM([Calculation_6146309593317412]))&#10;)&#10;/&#10;(&#10;WINDOW_MAX(SUM([Calculation_6146309593317412]))&#10;-&#10;WINDOW_MIN(SUM([Calculation_6146309593317412]))&#10;)&#10;* 100'>
                <table-calc ordering-field='[federated.1qrzfvr1ydsfw11d7qg0x13vauk4].[tokyo_ward]' ordering-type='Field' />
              </calculation>
            </column>
            <column caption='Vertical Density Index' datatype='real' name='[Calculation_6146308851593246]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='100 - ((AVG([volume_per_km2]) - WINDOW_MIN(AVG([volume_per_km2])))&#10;/&#10;(WINDOW_MAX(AVG([volume_per_km2])) - WINDOW_MIN(AVG([volume_per_km2])))&#10;* 100)'>
                <table-calc ordering-field='[federated.1qrzfvr1ydsfw11d7qg0x13vauk4].[tokyo_ward]' ordering-type='Field' />
              </calculation>
            </column>
            <column caption='Ground Coverage Index' datatype='real' name='[Calculation_6146308851875871]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='100 -((AVG([ground_coverage_percent]) - WINDOW_MIN(AVG([ground_coverage_percent])))&#10;/&#10;(WINDOW_MAX(AVG([ground_coverage_percent])) - WINDOW_MIN(AVG([ground_coverage_percent])))&#10;* 100)'>
                <table-calc ordering-field='[federated.1qrzfvr1ydsfw11d7qg0x13vauk4].[tokyo_ward]' ordering-type='Field' />
              </calculation>
            </column>
            <column caption='Flood Relief Index' datatype='real' name='[Calculation_6146308852072480]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='100 - ((AVG([pct_roof_area_proxy_in_high_flood_risk])&#10; - WINDOW_MIN(AVG([pct_roof_area_proxy_in_high_flood_risk])))&#10;/&#10;(WINDOW_MAX(AVG([pct_roof_area_proxy_in_high_flood_risk]))&#10; - WINDOW_MIN(AVG([pct_roof_area_proxy_in_high_flood_risk])))&#10;* 100)'>
                <table-calc ordering-field='[federated.1qrzfvr1ydsfw11d7qg0x13vauk4].[tokyo_ward]' ordering-type='Field' />
              </calculation>
            </column>
            <column caption='Green building yearly (LOD)' datatype='integer' name='[Calculation_6146309593317412]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [tokyo_ward], [eval_year] : COUNTD([id]) }' />
            </column>
            <column caption='Urban Relief Index' datatype='real' name='[Calculation_6146309603921958]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_6146308842442778]&#10; + [Calculation_6146308852072480]&#10; + [Calculation_6146308851875871]&#10; + [Calculation_6146308841357334]&#10; + [Calculation_6146308851593246])&#10;/&#10;5'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Tokyo Ward (en + jp)' datatype='string' name='[Calculation_6146310869979183]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[tokyo_ward] + &quot; (&quot; + [distric_name_jp] + &quot;)&quot;' />
            </column>
            <column datatype='spatial' name='[Geometry]' role='measure' type='nominal' />
            <column-instance column='[Calculation_6146310869979183]' derivation='Attribute' name='[attr:Calculation_6146310869979183:nk]' pivot='key' type='nominal' />
