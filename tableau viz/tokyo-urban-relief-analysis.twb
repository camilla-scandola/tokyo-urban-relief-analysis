      </column>
      <column caption='Growth Category' datatype='string' name='[Calculation_6146308453392385]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_6146308452495360] &gt; 20000 THEN &quot;green areas expanding&quot;&#10;ELSEIF [Calculation_6146308452495360] &lt; -20000 THEN &quot;green areas shrinking&quot;&#10;ELSE &quot;green areas stable&quot;&#10;END' />
