            <column caption='Tokyo Ward' datatype='string' name='[tokyo_ward]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_6146309603921958]' derivation='User' name='[usr:Calculation_6146309603921958:qk:10]' pivot='key' type='quantitative'>
