      <column caption='Flood Relief Index' datatype='real' name='[Calculation_6146308852072480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='100 - ((AVG([pct_roof_area_proxy_in_high_flood_risk])&#10; - WINDOW_MIN(AVG([pct_roof_area_proxy_in_high_flood_risk])))&#10;/&#10;(WINDOW_MAX(AVG([pct_roof_area_proxy_in_high_flood_risk]))&#10; - WINDOW_MIN(AVG([pct_roof_area_proxy_in_high_flood_risk])))&#10;* 100)'>
          <table-calc ordering-field='[federated.1qrzfvr1ydsfw11d7qg0x13vauk4].[tokyo_ward]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Green building yearly (LOD)' datatype='integer' name='[Calculation_6146309593317412]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [tokyo_ward], [eval_year] : COUNTD([id]) }' />
      </column>
      <column caption='Urban Relief Index' datatype='real' name='[Calculation_6146309603921958]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_6146308842442778]&#10; + [Calculation_6146308852072480]&#10; + [Calculation_6146308851875871]&#10; + [Calculation_6146308841357334]&#10; + [Calculation_6146308851593246])&#10;/&#10;5'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Quadrant Calculation' datatype='string' name='[Calculation_6146310617534507]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([park_percent_of_ward]) &gt;= WINDOW_AVG(AVG([park_percent_of_ward]))&#10;AND AVG([ground_coverage_percent]) &gt;= WINDOW_AVG(AVG([ground_coverage_percent]))&#10;THEN &quot;Dense &amp; Green&quot;&#10;&#10;ELSEIF AVG([park_percent_of_ward]) &gt;= WINDOW_AVG(AVG([park_percent_of_ward]))&#10;THEN &quot;Low Density &amp; Green&quot;&#10;&#10;ELSEIF AVG([ground_coverage_percent]) &gt;= WINDOW_AVG(AVG([ground_coverage_percent]))&#10;THEN &quot;Dense &amp; Low Green&quot;&#10;&#10;ELSE &quot;Low Density &amp; Low Green&quot;&#10;END'>
          <table-calc ordering-field='[federated.1qrzfvr1ydsfw11d7qg0x13vauk4].[tokyo_ward]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Current Green Level' datatype='real' name='[Calculation_6146310644994092]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MAX(AVG([park_percent_of_ward]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Green Growth (change over time)' datatype='real' name='[Calculation_6146310645129261]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MAX(AVG([park_percent_of_ward]))&#10;-&#10;WINDOW_MIN(AVG([park_percent_of_ward]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
