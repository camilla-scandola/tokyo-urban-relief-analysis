      <column caption='Green Areas Growth Rate (%)' datatype='real' default-format='p0.00%' name='[Calculation_5546870894678018]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6146308452495360] / &#10;{ FIXED [tokyo_ward (ward_parks_norm_year.csv)] :&#10;    MIN(IF [year] = { FIXED : MIN([year]) } THEN [park_area_m2] END)&#10;}' />
      </column>
      <column caption='Green Buildings Index (0–100)' datatype='real' name='[Calculation_5546871016407043]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#10;RUNNING_SUM(([Calculation_6146308847628315]))&#10;-&#10;WINDOW_MIN(RUNNING_SUM(([Calculation_6146308847628315])))&#10;)&#10;/&#10;(&#10;WINDOW_MAX(RUNNING_SUM(([Calculation_6146308847628315])))&#10;-&#10;WINDOW_MIN(RUNNING_SUM(([Calculation_6146308847628315])))&#10;)&#10;* 100'>
          <table-calc ordering-field='[federated.1qrzfvr1ydsfw11d7qg0x13vauk4].[year]' ordering-type='Field' />
