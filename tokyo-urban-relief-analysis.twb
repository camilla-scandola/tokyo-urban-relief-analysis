      <column caption='Green Areas Growth' datatype='real' name='[Calculation_6146308452495360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [tokyo_ward (ward_parks_norm_year.csv)] :&#10;    MAX(IF [year] = { FIXED : MAX([year]) } THEN [park_area_m2] END)&#10;}&#10;-&#10;{ FIXED [tokyo_ward (ward_parks_norm_year.csv)] :&#10;    MIN(IF [year] = { FIXED : MIN([year]) } THEN [park_area_m2] END)&#10;}' />
      </column>
      <column caption='Growth Category' datatype='string' name='[Calculation_6146308453392385]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_6146308452495360] &gt; 20000 THEN &quot;green areas expanding&quot;&#10;ELSEIF [Calculation_6146308452495360] &lt; -20000 THEN &quot;green areas shrinking&quot;&#10;ELSE &quot;green areas stable&quot;&#10;END' />
      </column>
      <column caption='Clean Rank' datatype='string' name='[Calculation_6146308781948940]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE TRIM([rank])&#10;WHEN &quot;Ａ&quot; THEN &quot;A&quot;&#10;WHEN &quot;Ｓ&quot; THEN &quot;S&quot;&#10;WHEN &quot;Ｂ+&quot; THEN &quot;B+&quot;&#10;WHEN &quot;Ｂ-&quot; THEN &quot;B-&quot;&#10;&#10;ELSE TRIM([rank])&#10;&#10;END' />
