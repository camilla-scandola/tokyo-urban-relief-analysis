    <worksheet name='Green Areas Growth'>
      <table>
        <view>
          <datasources>
            <datasource caption='casbee.csv+ (Multiple Connections)' name='federated.1qrzfvr1ydsfw11d7qg0x13vauk4' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.1qrzfvr1ydsfw11d7qg0x13vauk4'>
            <column caption='Green Areas Growth' datatype='real' name='[Calculation_6146308452495360]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [tokyo_ward (ward_parks_norm_year.csv)] :&#10;    MAX(IF [year] = { FIXED : MAX([year]) } THEN [park_area_m2] END)&#10;}&#10;-&#10;{ FIXED [tokyo_ward (ward_parks_norm_year.csv)] :&#10;    MIN(IF [year] = { FIXED : MIN([year]) } THEN [park_area_m2] END)&#10;}' />
            </column>
            <column caption='Growth Category' datatype='string' name='[Calculation_6146308453392385]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_6146308452495360] &gt; 20000 THEN &quot;green areas expanding&quot;&#10;ELSEIF [Calculation_6146308452495360] &lt; -20000 THEN &quot;green areas shrinking&quot;&#10;ELSE &quot;green areas stable&quot;&#10;END' />
            </column>
            <column caption='Tokyo Ward (en + jp)' datatype='string' name='[Calculation_6146310869979183]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[tokyo_ward] + &quot; (&quot; + [distric_name_jp] + &quot;)&quot;' />
            </column>
            <column datatype='spatial' name='[Geometry]' role='measure' type='nominal' />
            <column-instance column='[Geometry]' derivation='Collect' name='[clct:Geometry:nk]' pivot='key' type='nominal' />
            <column caption='District Name Jp' datatype='string' name='[distric_name_jp]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_6146308453392385]' derivation='None' name='[none:Calculation_6146308453392385:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_6146310869979183]' derivation='None' name='[none:Calculation_6146310869979183:nk]' pivot='key' type='nominal' />
            <column-instance column='[tokyo_ward]' derivation='None' name='[none:tokyo_ward:nk]' pivot='key' type='nominal' />
            <column-instance column='[year]' derivation='None' name='[none:year:ok]' pivot='key' type='ordinal' />
            <column caption='Park Area M2' datatype='real' name='[park_area_m2]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_6146308452495360]' derivation='Sum' name='[sum:Calculation_6146308452495360:qk]' pivot='key' type='quantitative' />
            <column caption='Tokyo Ward (Ward Parks Norm Year.Csv)' datatype='string' name='[tokyo_ward (ward_parks_norm_year.csv)]' role='dimension' type='nominal' />
            <column caption='Tokyo Ward' datatype='string' name='[tokyo_ward]' role='dimension' type='nominal' />
            <column caption='Year' datatype='integer' name='[year]' role='dimension' type='quantitative' />
